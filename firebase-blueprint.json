{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role and token tracking",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "tokenBalance": { "type": "number", "description": "Remaining tokens" },
        "isOnline": { "type": "boolean" },
        "lastActive": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "onboardingCompleted": { "type": "boolean" },
        "onboardingData": { "type": "object" },
        "levels": { "type": "object" },
        "xp": { "type": "number", "description": "Experience points" }
      },
      "required": ["email", "role", "tokenBalance", "createdAt"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A conversation thread",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single prompt or response",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sessionId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "content": { "type": "string" },
        "tokensUsed": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "sessionId", "role", "content", "tokensUsed", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A user's growth task",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "category", "isCompleted", "createdAt"]
    },
    "Finance": {
      "title": "Finance",
      "description": "Financial entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "category", "date", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/chat_sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Stores chat threads per user."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores individual chat messages."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores user tasks."
    },
    "/finances/{financeId}": {
      "schema": { "$ref": "#/entities/Finance" },
      "description": "Stores user financial entries."
    }
  }
}
